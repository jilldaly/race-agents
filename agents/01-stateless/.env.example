# Agent 01 — control plane (Gemini via the OpenAI-compatible endpoint).
# Copy to .env (gitignored) and fill in your Gemini API key. NB: Gemini's free
# tier is unavailable in the EU/UK — enable billing there (cost is ~cents).
GEMINI_API_KEY=

# Defaults (override only if needed):
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_TEMPERATURE=0
AGENT_MAX_STEPS=6
